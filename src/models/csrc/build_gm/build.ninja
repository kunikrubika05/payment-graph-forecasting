ninja_required_version = 1.3
cxx = c++

cflags = -DTORCH_EXTENSION_NAME=graph_metrics_cpp -DTORCH_API_INCLUDE_EXTENSION_H -isystem /Users/kunikrubika/Desktop/payment-graph-forecasting/venv/lib/python3.14/site-packages/torch/include -isystem /Users/kunikrubika/Desktop/payment-graph-forecasting/venv/lib/python3.14/site-packages/torch/include/torch/csrc/api/include -isystem /opt/homebrew/opt/python@3.14/Frameworks/Python.framework/Versions/3.14/include/python3.14 -fPIC -std=c++17 -O3
post_cflags = 
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = -shared -L/Users/kunikrubika/Desktop/payment-graph-forecasting/venv/lib/python3.14/site-packages/torch/lib -lc10 -ltorch_cpu -ltorch -ltorch_python -undefined dynamic_lookup

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc





rule link
  command = $cxx $in $ldflags -o $out

build graph_metrics.o: compile /Users/kunikrubika/Desktop/payment-graph-forecasting/src/models/csrc/graph_metrics.cpp





build graph_metrics_cpp.so: link graph_metrics.o

default graph_metrics_cpp.so
